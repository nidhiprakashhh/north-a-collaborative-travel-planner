# Copy this file to .env and fill in real values before running docker-compose up.
# .env is gitignored — never commit real secrets.

# ---- Server ----
NODE_ENV=development
PORT=4000

# ---- JWT (used starting Phase 2 — auth) ----
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- PostgreSQL ----
# Container runs from Phase 1 onward; the api service doesn't connect to it
# until Phase 3, when Prisma + the users/trips schema are introduced.
POSTGRES_USER=north_user
POSTGRES_PASSWORD=north_password
POSTGRES_DB=north_db

# ---- MongoDB ----
MONGO_URI=mongodb://mongodb:27017/north_preferences

# ---- Redis ----
REDIS_URL=redis://redis:6379

# ---- LLM (Groq — added in a later phase) ----
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
